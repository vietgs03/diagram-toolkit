{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"allowJs": false,
		"noEmit": true,
		"resolveJsonModule": true,
		"verbatimModuleSyntax": false
	},
	"include": ["src/**/*"]
}
